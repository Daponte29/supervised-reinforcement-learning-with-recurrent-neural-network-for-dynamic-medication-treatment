# Copy this file to .env and fill in values. Never commit .env.

# --- Experiment tracking ---
WANDB_API_KEY=
WANDB_PROJECT=my_project
WANDB_ENTITY=

# --- Data / storage ---
DATA_DIR=data/raw
PROCESSED_DIR=data/processed

# --- AWS (if using cloud infra) ---
AWS_REGION=us-east-1
S3_BUCKET=
ECR_REPO=

# --- Model serving ---
MODEL_PATH=
DEVICE=cuda          # cuda | cpu | mps
